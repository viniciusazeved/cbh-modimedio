# Copie este arquivo para `.streamlit/secrets.toml` (uso local) ou cole no painel
# do Streamlit Community Cloud em "Settings -> Secrets" no formato exato abaixo.
#
# IMPORTANTE: nao comitar `secrets.toml` real no GitHub.

FTP_HOST = "ip.servidor.aqui"
FTP_PORT = "21"
FTP_USER = "usuario_aqui"
FTP_PASS = "senha_aqui"
FTP_REMOTE_DIR = "/upload"
